{
  "name": "ansible-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {},
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.ansible",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "files.trimTrailingWhitespace": true,
        "yaml.validate": true,
        "ansible.validation.lint.enabled": true
      }
    }
  },
  "remoteEnv": {
    "ANSIBLE_CONFIG": "${containerWorkspaceFolder}/ansible.cfg",
    "LANG": "C.UTF-8",
    "LC_ALL": "C.UTF-8",
    "LANGUAGE": "C.UTF-8",
    "SHELL": "/bin/zsh"
  },
  "postCreateCommand": "ansible --version && ansible-lint --version",
  "remoteUser": "root"
}